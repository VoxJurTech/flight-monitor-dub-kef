# Copie este arquivo para .env e preencha com suas credenciais REAIS.
# NUNCA commitar o .env (já está no .gitignore).

# Travelpayouts (Aviasales) - fonte principal de cotações
TRAVELPAYOUTS_TOKEN=seu_token_aqui

# SerpAPI Google Flights - verificação semanal (opcional mas recomendado)
SERPAPI_KEY=sua_key_aqui

# Gmail para enviar alertas
GMAIL_USER=seu_email_remetente@gmail.com
GMAIL_APP_PASSWORD=sua_senha_de_app_aqui
ALERT_RECIPIENT=seu_email_destino@gmail.com

# Opcional: força verificação SerpAPI mesmo fora do dia da semana configurado
# FORCE_SERPAPI_CHECK=1
